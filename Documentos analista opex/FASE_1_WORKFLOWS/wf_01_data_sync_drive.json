    "Log Iteración": { "main": [[{ "node": "Split por Contratista", "type": "main", "index": 0 }]] },
    "Sheets: Leer Budget": { "main": [[{ "node": "Code: Validar Budget", "type": "main", "index": 0 }]] },
    "Code: Validar Budget": { "main": [[{ "node": "Postgres: Upsert Budget", "type": "main", "index": 0 }]] },
    "Postgres: Upsert Budget": { "main": [[{ "node": "Log OK", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1", "saveManualExecutions": true },
  "tags": [{ "name": "OPEX-BIA" }, { "name": "Fase-1" }, { "name": "Sync" }],
  "meta": {
    "notes": "Lee registro de contratistas desde hoja Config (pestaña Contratistas) → por cada contratista activo lee su Google Sheet individual → unpivot 3 grupos OR → upsert opex_tarifario. Rama B: sync budget desde sheet separado. Agregar/quitar contratistas editando la hoja Config."
  }
}
